cdninstagram.com&_nc_gid=E4KOL2LfKBpkcEMtKmFzpg&_nc_ss=7a289&oh=00_Af1SCxc5fHAmVkjyx_-fBke5VKDu8TmMZ6_HsogcUaEO7Q&oe=69EE2DC0","type":"image"}],"tags":["旅遊","福岡"],"removed":false,"collection":{"$ref":"collections","$id":70031060,"oid":70031060},"highlights":[],"created":"2026-04-22T06:01:10.112Z","lastUpdate":"2026-04-22T08:55:12.859Z","domain":"instagram.com","title":"福岡。博多 - 枕頭","creatorRef":{"_id":6938240,"avatar":"","name":"baka-hanako","email":""},"sort":1692620791,"collectionId":70031060},{"_id":1692619865,"link":"https://www.instagram.com/reel/DRRdyzqETuB/?igsh=NW16OHpha3Q1cjhq","excerpt":"604 likes, 9 comments - jazz10242008 on November 20, 2025: \"弘大超隱密的炒年糕小店\n真的藏在超小的巷弄裡\n遠遠看超不起眼\n走進看~店內滿滿的用餐人潮\n\n和朋友大概五點左右到，明明還沒到吃飯時間\n店裡已經整間坐滿，還要候補 😳\n\n店內布置得像韓國傳統布帳馬車\n很有那種在地路邊攤的復古氛圍感\n\n他們的炒年糕也超特別\n不是一般的辣炒年糕 而是 年糕＋燉雞一起煮 \n等於一次吃到兩種料理的滿足感\n\n雞肉真的燉的超入味、年糕也好Q彈\n而且眼前看到的所有配料 還是免費提供的\n是不是很誇張？\n\n份量大、料又多 真的完全是真材實料！\n難怪五點不到就客滿\n真的好吃到會懂韓國人為什麼排隊也願意\n超適合三五好友一起來分著吃\n推薦給你們，下次來弘大一定要試試~\n\n————————————\n▪️店名：떡볶이상회 年糕商會 弘大\n▪️地址: 서울 마포구 어울마당로 143-3 1층\n▪️營業時間：12:00-22:30（15:00-16:00 BR)\n▪️電話：0507-1344-7658\n（🔍Naver map 韓文店名,電話或地址，可直接搜尋店位置）\n————————————\n\n#韓國自助旅 #韓國自由行 #首爾自由行 #首爾自助旅  #韓國美食 #韓國必吃 #弘大 #弘大美食 #韓式年糕 #辣炒年糕 #홍대맛집 #떡볶이상회 #떡볶이맛집 #홍대떡볶이\".","note":"떡볶이상회 年糕商會 弘大 | 서울 마포구 어울마당로 143-3 1층 | ","type":"image","user":{"$ref":"users","$id":6938240},"cover":"https://scontent-dus1-1.cdninstagram.com/v/t51.82787-15/583151947_18534486703023399_5947489821431599078_n.jpg?stp=cmp1_dst-jpg_e35_s640x640_tt6&_nc_cat=101&ccb=7-5&_nc_sid=18de74&efg=eyJlZmdfdGFnIjoiQ0xJUFMuYmVzdF9pbWFnZV91cmxnZW4uQzMifQ%3D%3D&_nc_ohc=Jm7bg2BXS-YQ7kNvwFnUEY5&_nc_oc=AdqNUyMJTok_UqjWGMPVNK8IAxN5ZicH0VXzWDHS1lD3Bq23gr7CjSlEMAfMDsWFUFc&_nc_zt=23&_nc_ht=scontent-dus1-1.cdninstagram.com&_nc_gid=Oo5LBZno4JTTdgkE41yt7w&_nc_ss=7a289&oh=00_Af12VqPp8WrV-OxfBoX4lcLIIekzM-0DJxQjrZb9nIhExw&oe=69EE3F29","media":[{"link":"https://scontent-dus1-1.cdninstagram.com/v/t51.82787-15/583151947_18534486703023399_5947489821431599078_n.jpg?st